# =============================================================================
# Apache2 Configuration for Resort Reservation System
# =============================================================================

# Enable Rewrite Engine
RewriteEngine On

# --- HTTPS Enforcement ---
# Since you're using a Cloudflare Tunnel, Cloudflare handles SSL for the user.
# Your laptop sees HTTP from the tunnel, so don't force HTTPS here or you'll get a redirect loop.
# Only uncomment if you notice the tunnel isn't forcing HTTPS automatically.
# RewriteCond %{HTTP:X-Forwarded-Proto} !https
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --- Security Headers ---
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    
    # Updated CSP: Added Cloudflare domains to allow the tunnel/CDN to function
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; font-src 'self' https://cdnjs.cloudflare.com; img-src 'self' data:; connect-src 'self'"

    # Remove server version info (Note: 'Server' header often requires mod_security to truly hide)
    Header unset X-Powered-By
</IfModule>

# --- Block access to sensitive directories ---
# FIXED: Replaced <DirectoryMatch> (not allowed in htaccess) with RewriteRules
RewriteRule ^(config|helpers|scripts|logs|tmp|database|output|vendor)/ - [F,L]

# --- Block access to sensitive files ---
<FilesMatch "\.(env|sql|md|log|sh|gitignore|htpasswd)$">
    Require all denied
</FilesMatch>

# Block access to dot files (like .git, .env, etc.)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# --- Prevent Directory Listing ---
Options -Indexes

# --- Default Character Set ---
AddDefaultCharset UTF-8

# --- PHP Settings ---
<IfModule mod_php7.c>
    # Note: Use mod_php.c if on PHP 8+, or mod_php7.c for PHP 7
    php_flag display_errors Off
    php_flag log_errors On
    # Ensure this path is writable by the 'www-data' user!
    php_value error_log /home/davon/resort-reservation-system/logs/php_errors.log
    php_flag expose_php Off
    php_value session.cookie_httponly 1
    php_value session.cookie_samesite Strict
    php_value session.use_strict_mode 1
    php_value session.use_only_cookies 1
</IfModule>

# --- Compression ---
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css application/json
    AddOutputFilterByType DEFLATE application/javascript text/xml application/xml
</IfModule>

# --- Browser Caching for Static Assets ---
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>